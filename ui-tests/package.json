{
  "name": "element-ui-tests",
  "version": "0.1.0",
  "private": true,
  "description": "Webdriver.io UI tests for Element (web + mobile via Appium)",
  "scripts": {
    "test:web": "wdio run config/wdio.web.conf.ts",
    "test:android": "wdio run config/wdio.android.conf.ts",
    "test:ios": "wdio run config/wdio.ios.conf.ts",
    "synapse:setup": "bash scripts/setup-synapse.sh",
    "synapse:up": "docker compose up -d",
    "synapse:down": "docker compose down",
    "synapse:logs": "docker compose logs -f synapse"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.14.0",
    "@wdio/appium-service": "^9.27.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/globals": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "appium": "^3.3.0",
    "appium-uiautomator2-driver": "^7.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0",
    "undici": "^6.19.0",
    "webdriverio": "^9.0.0"
  },
  "comments": {
    "phase2_android_deps": "@wdio/appium-service, appium — Installation: npm install -D @wdio/appium-service appium; appium driver install uiautomator2",
    "phase3_ios_deps": "@wdio/appium-service, appium — Installation: npm install -D @wdio/appium-service appium; appium driver install xcuitest"
  }
}
